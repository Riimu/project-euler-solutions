{
    "require": {
        "php": ">=8.5",
        "ext-gmp": "*",
        "symfony/console": "^8.0",
        "symfony/finder": "^8.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.95",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^13.1"
    },
    "autoload": {
        "psr-4": {
            "Riimu\\EulerSolver\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Riimu\\EulerSolver\\Test\\": "tests"
        }
    },
    "scripts": {
        "analyse": "phpstan analyse",
        "fix": "php-cs-fixer fix --verbose --diff",
        "test": "phpunit"
    }
}
